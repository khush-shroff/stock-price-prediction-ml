# Stock Price Prediction - Mini Project
# Tried using ML to predict stock closing price based on past data

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import yfinance as yf

# getting data from yahoo finance
stock = "RELIANCE.NS"
df = yf.download(stock, start="2017-01-01", end="2024-01-01")

# only using closing price for now
df = df[['Close']]

# creating some basic features
# idea: previous days might influence next day price

df['prev_day'] = df['Close'].shift(1)
df['prev_2_day'] = df['Close'].shift(2)

# moving averages (to smooth data)
df['ma5'] = df['Close'].rolling(5).mean()
df['ma10'] = df['Close'].rolling(10).mean()

# simple RSI (not using library, tried manually)
change = df['Close'].diff()
gain = change.where(change > 0, 0)
loss = -change.where(change < 0, 0)

avg_gain = gain.rolling(14).mean()
avg_loss = loss.rolling(14).mean()

rs = avg_gain / avg_loss
df['rsi'] = 100 - (100 / (1 + rs))

# removing null values after feature creation
df = df.dropna()

# splitting data (not shuffling because time series)
split = int(len(df) * 0.8)

train = df[:split]
test = df[split:]

X_train = train.drop('Close', axis=1)
y_train = train['Close']

X_test = test.drop('Close', axis=1)
y_test = test['Close']

# trying Random Forest ( for non-linear data)
from sklearn.ensemble import RandomForestRegressor

model = RandomForestRegressor(n_estimators=80, random_state=0)
model.fit(X_train, y_train)

# prediction
pred = model.predict(X_test)

# checking error
from sklearn.metrics import mean_squared_error

rmse = np.sqrt(mean_squared_error(y_test, pred))
print("RMSE value:", rmse)

# plotting actual vs predicted
plt.figure(figsize=(10,5))
plt.plot(y_test.values, label="Actual")
plt.plot(pred, label="Predicted")
plt.legend()
plt.title("Stock Price Prediction")
plt.show()
